DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

NXAPI_USER_AGENT=nxapi-discord-bot/1.0.0 (+https://github.com/YukkuriSany/nxapi-discord-bot)
NXAPI_DATA_PATH=/data
NXAPI_DEBUG_FILE=0
NXAPI_TIMEOUT_MS=45000
# GitHub開発版の取得ブランチまたはタグ
NXAPI_GIT_REF=main
# ソースビルドでCoral認証に必要になる場合があります
# https://nxapi-auth.fancy.org.uk/oauth/clients で発行
NXAPI_AUTH_CLIENT_ID=

# Bot側の最大サイズ（MiB）。実際にはDiscordがInteractionで通知する上限を優先
VIDEO_MAX_SIZE_MB=100
# 動画取得処理のタイムアウト（ミリ秒）
VIDEO_DOWNLOAD_TIMEOUT_MS=180000

# 空欄なら全員利用可能。制限する場合はDiscordユーザーIDをカンマ区切りで指定
ALLOWED_DISCORD_USER_IDS=
